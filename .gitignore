# Icon build intermediates
build/icon.iconset/
build/icon/wireguide.icns

# Compiled asset catalog — regenerated by `wails3 generate icons` from
# build/appicon.icon. Must NOT be committed: if present in the .app
# bundle, macOS prioritises it over icons.icns via CFBundleIconName,
# which caused persistent icon-cache issues during development.
build/darwin/Assets.car

# Claude Code working files — plans and local settings are per-user, not
# repo state.
.claude/
.spec-mix/

# Helper debugging artifacts (stderr captures from `task build DEV=true`
# launches with WIREGUIDE_HELPER_STDERR=1). Repo-relative, throwaway.
debug-logs/
